local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local CoreGui = game:GetService("CoreGui")
local player = Players.LocalPlayer

local parent = nil
if gethui then
    parent = gethui()
elseif CoreGui:FindFirstChild("RobloxGui") then
    parent = CoreGui.RobloxGui
else
    parent = player:WaitForChild("PlayerGui")
end

task.spawn(function()
    local tradeGui = parent:WaitForChild("TradeGUI_Phone", 20)
    if not tradeGui then
        tradeGui = player:WaitForChild("PlayerGui"):FindFirstChild("TradeGUI_Phone")
    end

    if not tradeGui then
        warn("[FakeTrade] ERROR: UI not found!")
        return
    end

    tradeGui.Enabled = false

    -- Fix "cover" frames
    for _, desc in ipairs(tradeGui:GetDescendants()) do
        if string.lower(desc.Name) == "cover" then
            desc.ZIndex = -1
            if desc:IsA("GuiObject") then desc.Active = false end
        end
    end

    local container = tradeGui:WaitForChild("Container")
    local tradePanel = container:WaitForChild("Trade")
    local actions = tradePanel:WaitForChild("Actions")
    local itemsPanel = container:WaitForChild("Items")

    -- Buttons
    local acceptBtn = actions.Accept.ActionButton
    local declineBtn = actions.Decline.ActionButton
    local addItemsBtn = actions.AddItems.ActionButton
    
    -- Back Button for mobile
    local closeItemsBtn = itemsPanel:WaitForChild("Tabs"):WaitForChild("Close"):WaitForChild("ActionButton")

    acceptBtn.ZIndex = 100
    declineBtn.ZIndex = 100
    addItemsBtn.ZIndex = 100
    closeItemsBtn.ZIndex = 100

    -- Offers
    local offer1 = tradePanel.Offer1.Container
    local offer2 = tradePanel.Offer2
    local offer2Container = offer2.Container
    local offer2Username = offer2.Username
    local offer1Accepted = tradePanel.Offer1.Accepted
    local offer2Accepted = offer2.Accepted

    -- Template for items
    local newItemTemplate = itemsPanel:FindFirstChild("NewItem", true)
    local invGrid = itemsPanel:FindFirstChild("Container", true)

    -- State
    local myOffer = {}
    local targetHasAccepted = false
    local canAccept = false
    local currentTick = 0
    
    -- Fake inventory with quantities
    local myInventoryData = {
        ["Nik's Scythe"] = {Amount = 5, Texture = "rbxassetid://2957790421"},
        ["Harvester"] = {Amount = 2, Texture = "rbxassetid://2957790421"},
        ["Corrupt"] = {Amount = 1, Texture = "rbxassetid://2957790421"},
        ["Batwing"] = {Amount = 10, Texture = "rbxassetid://2957790421"}
    }

    local function updateSlots(slotsFrame, itemsList)
        for _, child in ipairs(slotsFrame:GetChildren()) do
            if child:IsA("Frame") or child:IsA("TextButton") then child:Destroy() end
        end
        local layout = Instance.new("UIGridLayout", slotsFrame)
        layout.CellSize = UDim2.new(0, 70, 0, 70)
        layout.CellPadding = UDim2.new(0, 5, 0, 5)

        for _, item in ipairs(itemsList) do
            if newItemTemplate then
                local clone = newItemTemplate:Clone()
                clone.Visible = true
                clone.ItemName.Label.Text = item.Name
                local icon = clone:FindFirstChild("Icon", true)
                if icon then icon.Image = item.Texture end
                
                -- Hide quantity in the offer slots to look clean
                local amountLabel = clone:FindFirstChild("Amount", true)
                if amountLabel then amountLabel.Visible = false end
                
                clone.Parent = slotsFrame
                
                local btn = Instance.new("TextButton", clone)
                btn.Size = UDim2.new(1,0,1,0)
                btn.BackgroundTransparency = 1
                btn.Text = ""
                btn.ZIndex = 10
                btn.MouseButton1Click:Connect(function()
                    -- Remove from offer and return to inventory
                    for i, v in ipairs(myOffer) do
                        if v == item then
                            table.remove(myOffer, i)
                            myInventoryData[item.Name].Amount = myInventoryData[item.Name].Amount + 1
                            updateSlots(offer1, myOffer)
                            -- Redraw inventory to show updated count
                            return
                        end
                    end
                end)
            end
        end
    end

    local function populateInventory()
        if not invGrid then return end
        for _, child in ipairs(invGrid:GetChildren()) do
            if child.Name ~= "NewItem" and child:IsA("Frame") then child:Destroy() end
        end

        for name, data in pairs(myInventoryData) do
            if newItemTemplate and data.Amount > 0 then
                local clone = newItemTemplate:Clone()
                clone.Name = name
                clone.Visible = true
                clone.ItemName.Label.Text = name
                
                local icon = clone:FindFirstChild("Icon", true)
                if icon then icon.Image = data.Texture end
                
                local amountLabel = clone:FindFirstChild("Amount", true)
                if amountLabel then 
                    amountLabel.Text = "x" .. tostring(data.Amount) 
                    amountLabel.Visible = true
                end
                
                clone.Parent = invGrid

                local btn = Instance.new("TextButton", clone)
                btn.Size = UDim2.new(1,0,1,0)
                btn.BackgroundTransparency = 1
                btn.Text = ""
                btn.ZIndex = 10
                btn.MouseButton1Click:Connect(function()
                    if #myOffer < 4 and data.Amount > 0 then
                        data.Amount = data.Amount - 1
                        table.insert(myOffer, {Name = name, Texture = data.Texture})
                        updateSlots(offer1, myOffer)
                        populateInventory() -- Refresh inventory list
                    end
                end)
            end
        end
    end

    local function startCooldown()
        canAccept = false
        actions.Accept.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
        currentTick = tick()
        local myTick = currentTick
        local title = actions.Accept:FindFirstChild("Title", true) or actions.Accept:FindFirstChildOfClass("TextLabel", true)
        
        task.spawn(function()
            for i = 6, 1, -1 do
                if myTick ~= currentTick then return end
                if title then title.Text = i .. "s" end
                task.wait(1)
            end
            if myTick == currentTick then
                canAccept = true
                actions.Accept.BackgroundColor3 = Color3.fromRGB(0, 240, 0)
                if title then title.Text = "ACCEPT" end
            end
        end)
    end

    -- Control Panel
    local controlGui = Instance.new("ScreenGui", parent)
    controlGui.Name = "FakeTradeControl"

    local frame = Instance.new("Frame", controlGui)
    frame.Size = UDim2.new(0, 200, 0, 150)
    frame.Position = UDim2.new(0.5, -100, 0, 10)
    frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
    frame.Draggable = true
    frame.Active = true

    local nameInput = Instance.new("TextBox", frame)
    nameInput.Size = UDim2.new(1,0,0,30)
    nameInput.Text = "Nikilis"

    local startBtn = Instance.new("TextButton", frame)
    startBtn.Size = UDim2.new(1,0,0,40)
    startBtn.Position = UDim2.new(0,0,0,40)
    startBtn.Text = "Open Trade"

    local acceptBtnCtrl = Instance.new("TextButton", frame)
    acceptBtnCtrl.Size = UDim2.new(1,0,0,40)
    acceptBtnCtrl.Position = UDim2.new(0,0,0,90)
    acceptBtnCtrl.Text = "Force Accept"

    startBtn.MouseButton1Click:Connect(function()
        offer2Username.Text = "(" .. nameInput.Text .. ")"
        tradeGui.Enabled = true
        myOffer = {}
        updateSlots(offer1, myOffer)
        populateInventory()
        startCooldown()
    end)

    -- Button Connections
    addItemsBtn.MouseButton1Click:Connect(function()
        itemsPanel.Visible = true
        populateInventory()
    end)
    
    closeItemsBtn.MouseButton1Click:Connect(function()
        itemsPanel.Visible = false
    end)

    declineBtn.MouseButton1Click:Connect(function()
        tradeGui.Enabled = false
        itemsPanel.Visible = false
    end)

    acceptBtn.MouseButton1Click:Connect(function()
        if canAccept then
            offer1Accepted.Visible = true
            actions.Accept.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
            if targetHasAccepted then
                task.wait(1)
                tradeGui.Enabled = false
            end
        end
    end)

    acceptBtnCtrl.MouseButton1Click:Connect(function()
        targetHasAccepted = true
        offer2Accepted.Visible = true
        if offer1Accepted.Visible then
            task.wait(1)
            tradeGui.Enabled = false
        end
    end)

    print("[FakeTrade] Setup complete.")
end)
